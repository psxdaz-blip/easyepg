{
  "name": "easyepg",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "deploy:playlist": "wrangler deploy workers/playlist-router/index.ts --name playlist-router --keep-vars",
    "deploy:logo": "wrangler deploy workers/logo-cdn/index.ts --name logo-cdn --keep-vars",
    "deploy:cname": "wrangler deploy workers/cname-verifier/index.ts --name cname-verifier --keep-vars",
    "deploy:all": "npm run deploy:playlist && npm run deploy:logo && npm run deploy:cname"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.0",
    "next": "^16.2.7",
    "openai": "^6.42.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "source-map-js": "^1.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.1",
    "eslint-config-next": "^16.2.7",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.98.0"
  }
}
